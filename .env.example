# ==============================================
# AEONSPORTS PRODUCTION ENVIRONMENT VARIABLES
# ==============================================

# Node Environment
NODE_ENV=production

# App Configuration
NEXT_PUBLIC_APP_URL=https://aeonsports.com
NEXT_PUBLIC_SITE_NAME=AeonSports
NEXT_PUBLIC_SITE_DESCRIPTION=AI-powered sports tokenization platform on Base blockchain

# ==============================================
# SUPABASE CONFIGURATION
# ==============================================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ==============================================
# AI CONFIGURATION
# ==============================================
OPENAI_API_KEY=your_anthropic_api_key

# ==============================================
# FIFA API CONFIGURATION
# ==============================================
FIFA_API_KEY=your_api_football_key
FIFA_API_BASE_URL=https://v3.football.api-sports.io

# ==============================================
# BLOCKCHAIN CONFIGURATION
# ==============================================
BASE_RPC_URL=https://mainnet.base.org
CHAIN_ID=8453

# Treasury Wallet Configuration
# CRITICAL: Never commit your private key to version control
TREASURY_WALLET_PRIVATE_KEY=your_wallet_private_key_here
TREASURY_WALLET_ADDRESS=0xC4D2b2F17A768429bEEdaeD946572F0A48afb7Cd

# ==============================================
# TOKEN LAUNCH PLATFORMS
# ==============================================
# Clanker v4.0.0 API Configuration
CLANKER_API_URL=https://www.clanker.world
CLANKER_API_KEY=your_clanker_api_key

# Flaunch API Configuration
FLAUNCH_API_URL=https://api.flaunch.io
FLAUNCH_API_KEY=your_flaunch_api_key

# ==============================================
# RATE LIMITING (UPSTASH REDIS)
# ==============================================
UPSTASH_REDIS_REST_URL=your_upstash_redis_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# ==============================================
# ERROR MONITORING (SENTRY)
# ==============================================
SENTRY_DSN=your_sentry_dsn
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn
SENTRY_AUTH_TOKEN=your_sentry_auth_token
SENTRY_ORG=your_sentry_org
SENTRY_PROJECT=aeonsports

# ==============================================
# SECURITY
# ==============================================
# Admin Dashboard Password
ADMIN_PASSWORD=your_secure_admin_password_here

# Cron Job Security (Vercel)
CRON_SECRET=your_random_cron_secret_here
INTERNAL_API_SECRET=your_random_internal_api_secret_here

# ==============================================
# LOGGING
# ==============================================
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true
