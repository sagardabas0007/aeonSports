# Copy this file to .env.local and fill in your actual values
# .env.local is gitignored and safe for local development

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic AI Configuration
OPENAI_API_KEY=

# FIFA API Configuration
FIFA_API_KEY=

# Base Network Configuration
BASE_RPC_URL=https://mainnet.base.org

# Treasury Wallet Configuration
TREASURY_WALLET_PRIVATE_KEY=
TREASURY_WALLET_ADDRESS=0xC4D2b2F17A768429bEEdaeD946572F0A48afb7Cd

# Token Launch Platform APIs
CLANKER_API_URL=https://api.clanker.world
CLANKER_API_KEY=

FLAUNCH_API_URL=https://api.flaunch.io
FLAUNCH_API_KEY=

NODE_ENV=development

# Cron Job Security
CRON_SECRET=dev-secret
INTERNAL_API_SECRET=dev-secret

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
